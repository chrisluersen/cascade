# Cascade runtime environment
# Copy this to .env and fill in your values
#
# BWS_ACCESS_TOKEN is the bootstrap key — cascade loads ALL secrets
# from Bitwarden at startup (including CASCADE_API_KEY, OLLAMA_MODEL,
# and every provider API key).
#
# OLLAMA_MODEL now comes from Bitwarden. Cascade resolves all config
# through _BW_KEYS first, then os.environ, then hardcoded defaults.
#
# When Hermes Agent is installed, cascade falls back to
# ~/AppData/Local/hermes/.env for the BWS token automatically —
# you can skip creating cascade's own .env entirely.
BWS_ACCESS_TOKEN=<your-bitwarden-session-token>

# If you're NOT using Bitwarden, OR running cascade standalone without Hermes,
# add keys directly:
# CASCADE_API_KEY=<your-cascade-api-key>
# OPENAI_API_KEY=sk-...