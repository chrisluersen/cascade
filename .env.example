# Cascade runtime environment
# Copy this to .env and fill in your values
#
# BWS_ACCESS_TOKEN is the bootstrap key — cascade loads ALL secrets
# from Bitwarden at startup (including CASCADE_API_KEY, OLLAMA_MODEL,
# and every provider API key). If BWS is available you don't need
# to list individual keys here.
#
# OLLAMA_MODEL is a local preference kept in .env because it's not
# a secret — just which Ollama model to offer.
BWS_ACCESS_TOKEN=<your-bitwarden-session-token>
OLLAMA_MODEL=qwen3.5:9b-16k

# If you're NOT using Bitwarden, add keys directly:
# CASCADE_API_KEY=<your-cascade-api-key>
# OPENAI_API_KEY=sk-...