# ── Authentication ─────────────────────────────────────────────────────────────
# Keys that clients use to authenticate with cascade (comma-separated)
PROXY_API_KEYS=sk-my-router-key-1

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8319
LOG_LEVEL=INFO

# ── Provider API Keys ──────────────────────────────────────────────────────────
# Add multiple keys per provider for higher throughput and fewer rate-limit hits.
# Providers tried in order: Gemini → OpenRouter → SambaNova → GitHub Models → Cerebras → Groq → Mistral → Cohere → Z.ai (GLM) → Naga → NVIDIA NIM
# Any provider with no keys configured is skipped automatically.
#
# Three ways to supply multiple keys (all are combined automatically):
#   GROQ_API_KEY=key1                   # single key
#   GROQ_API_KEYS=key1,key2,key3        # comma-separated
#   GROQ_API_KEY_2=key2                 # numbered suffixes (_2, _3, ...)

# Google Gemini (free tier, resets per minute — get keys at aistudio.google.com)
GEMINI_API_KEYS=AIzaSy_key1,AIzaSy_key2,AIzaSy_key3

# OpenRouter (50 free requests/day per key — get keys at openrouter.ai)
OPENROUTER_API_KEYS=sk-or-key1,sk-or-key2

# SambaNova (free, fast Llama models — get key at cloud.sambanova.ai)
SAMBANOVA_API_KEY=your-sambanova-key

# GitHub Models (free with any GitHub account — use a GitHub PAT or OAuth token)
# Generate at: github.com/settings/tokens (no special scopes needed)
GITHUB_MODELS_TOKEN=ghp_or_gho_your-token

# Cerebras (fast inference, free tier — get key at cloud.cerebras.ai)
CEREBRAS_API_KEY=csk-your-key

# Groq (fast inference, free tier — get key at console.groq.com)
GROQ_API_KEY=gsk_your-key

# Mistral (free tier, mistral-medium-latest — get key at console.mistral.ai)
MISTRAL_API_KEY=your-mistral-key

# Cohere (free trial, 1000 calls/mo per key, command-a 256K ctx — get key at dashboard.cohere.com)
COHERE_API_KEY=your-cohere-key

# Z.ai / GLM (free, glm-4.5-flash, ~1k req/day — get key at z.ai)
GLM_API_KEY=your-zai-key

# Naga AI (free, Nemotron-3-Super-120B, 100 req/day per key — get key at naga.ac)
NAGA_API_KEY=ng-your-key
# NAGA_API_KEY_2=ng-second-key
# NAGA_API_KEY_3=ng-third-key

# NVIDIA NIM (free, DeepSeek V4 Flash, 1M context, 40 req/min per key — get key at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key
# NVIDIA_API_KEY_2=nvapi-second-key
# NVIDIA_API_KEY_3=nvapi-third-key

# ── Model Overrides (optional) ─────────────────────────────────────────────────
# Uncomment to use a different model for any provider.
# GEMINI_MODEL=gemini-2.5-flash-lite
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# SAMBANOVA_MODEL=DeepSeek-V3.2
# GITHUB_MODELS_MODEL=gpt-4o            # gpt-4o-mini for a lighter, higher-quota option
# CEREBRAS_MODEL=gpt-oss-120b
# GROQ_MODEL=llama-3.3-70b-versatile
# MISTRAL_MODEL=mistral-medium-latest
# COHERE_MODEL=command-a-03-2025
# ZAI_MODEL=glm-4.5-flash
# NAGA_MODEL=nemotron-3-super-120b-a12b:free   # or nemotron-3-ultra-550b-a55b:free (slower)
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

# ── OpenRouter Metadata (optional) ────────────────────────────────────────────
# OPENROUTER_SITE_URL=https://your-site.com
# OPENROUTER_APP_NAME=my-app

# ── Model ID (optional) ───────────────────────────────────────────────────────
# The model name advertised at /v1/models and accepted in requests.

# ── Response Cache (optional) ─────────────────────────────────────────────────
# Cache identical requests' responses to save free-tier quota.
# The cache is shared across all clients — if you serve multiple
# untrusted users, set it to 0.
# CACHE_TTL_SECONDS=300
# CACHE_MAX_SIZE=100

# ── Fast Routing (optional) ───────────────────────────────────────────────────
# For short requests below this estimated token count, low-latency providers
# (Groq, Cerebras, SambaNova) win ties between equally-rated providers.
# Set to 0 (default) to disable.
# FAST_ROUTE_THRESHOLD=200

# ── Provider probe cache (optional) ───────────────────────────────────────────
# Startup probes spend one tiny completion per provider. Saved results are
# reused for this many hours before re-probing (0 = re-probe on every start).
# PROBE_STATE_TTL_HOURS=24

# ── Large-payload skip (optional) ─────────────────────────────────────────────
# Some free tiers reject big requests outright (e.g. Groq's free tier caps
# tokens-per-minute around 6000 and returns 413). cascade skips such a
# provider when your request is estimated to exceed its ceiling, avoiding a
# wasted failed attempt before cascading on.
#   {PROVIDER}_SKIP_TOKENS_OVER  — set 0 to disable, or raise it on a paid tier.
# Sensible defaults are built in even if you don't set these; override here:
# GROQ_SKIP_TOKENS_OVER=5500            # ~6K TPM free tier → 413
# SAMBANOVA_SKIP_TOKENS_OVER=30000      # DeepSeek-V3.2 here caps at 32K context → 400
# GITHUB_MODELS_SKIP_TOKENS_OVER=6000   # gpt-4o free tier ~8K input limit → 413
# CEREBRAS_SKIP_TOKENS_OVER=0

# Some providers reject the WHOLE request with a 400 if max_tokens exceeds their
# output cap (e.g. a client sending max_tokens=65536). cascade clamps the
# requested output down to the provider's ceiling so the call still succeeds.
#   {PROVIDER}_MAX_OUTPUT_TOKENS  — set 0 to disable the clamp.
# COHERE_MAX_OUTPUT_TOKENS=8192          # command-a caps output at 8192
# GITHUB_MODELS_MAX_OUTPUT_TOKENS=16384  # gpt-4o here rejects very large max_tokens

# ── Circuit breaker (optional) ────────────────────────────────────────────────
# A provider that fails health checks repeatedly (network errors or 5xx — not
# rate-limits or bad requests) is tripped out of rotation for a cooldown, then
# probed again. Unhealthy providers also sink in the routing order automatically.
# Defaults shown; uncomment to tune.
# BREAKER_WINDOW=8           # how many recent outcomes to weigh
# BREAKER_MIN_SAMPLES=4      # min samples before the breaker can trip
# BREAKER_ERROR_RATE=0.5     # trip when >= this fraction of the window are health-fails
# BREAKER_COOLDOWN=60        # seconds the breaker stays open before re-probing
